---

# Example Starter Code

```python
import speech_recognition as sr
import pyttsx3
import datetime

engine = pyttsx3.init()
recognizer = sr.Recognizer()

def speak(text):
    print("clAIre:", text)
    engine.say(text)
    engine.runAndWait()

def listen():
    with sr.Microphone() as source:
        print("Listening...")
        audio = recognizer.listen(source)

    try:
        command = recognizer.recognize_google(audio)
        print("User:", command)
        return command.lower()
    except:
        return ""

def emergency_call():
    speak("Calling emergency contact now.")

def medication_reminder():
    current_hour = datetime.datetime.now().hour

    if current_hour == 9:
        speak("Reminder: It is time to take your morning medication.")

def process_command(command):

    if "hello" in command:
        speak("Hello! How can I assist you today?")

    elif "help" in command or "emergency" in command:
        emergency_call()

    elif "medication" in command:
        speak("Checking medication schedule now.")

    elif "stop" in command:
        speak("Shutting down. Stay safe.")
        return False

    else:
        speak("I did not understand that command.")

    return True

speak("Hello, I am clAIre, your assistive AI companion.")

running = True

while running:
    medication_reminder()

    command = listen()

    if command:
        running = process_command(command)
```

